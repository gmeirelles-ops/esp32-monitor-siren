rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    function isAuthenticated() {
      return request.auth != null;
    }

    function hasStationId() {
      return request.resource.data.keys().hasAll(['station_id'])
        && request.resource.data.station_id is string
        && request.resource.data.station_id.size() > 0;
    }

    match /devices/{deviceId} {
      allow read, write: if isAuthenticated();
    }

    match /test_results/{docId} {
      allow read: if isAuthenticated();
      allow create, update: if isAuthenticated() && hasStationId();
      allow delete: if false;

      match /seriais/{serial} {
        allow read: if isAuthenticated();
        allow create, update: if isAuthenticated() && hasStationId();
        allow delete: if false;
      }

      match /reprovadas/{sequencial} {
        allow read: if isAuthenticated();
        allow create, update: if isAuthenticated() && hasStationId();
        allow delete: if false;
      }
    }

    match /batches/{batchId} {
      allow read: if isAuthenticated();
      allow write: if false;
    }

    match /products/{productId} {
      allow read, write: if isAuthenticated();
    }

    match /operators/{codigo} {
      allow read, write: if isAuthenticated();
    }

    // Collection group queries (app gestor — analytics em seriais/reprovadas)
    match /{path=**}/seriais/{serial} {
      allow read: if isAuthenticated();
      allow create, update: if isAuthenticated() && hasStationId();
      allow delete: if false;
    }

    match /{path=**}/reprovadas/{sequencial} {
      allow read: if isAuthenticated();
      allow create, update: if isAuthenticated() && hasStationId();
      allow delete: if false;
    }
  }
}
