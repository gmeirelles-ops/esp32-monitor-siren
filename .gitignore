sirene-validator/sdkconfig.defaults.old
sirene-validator/host_tests/build/

# Node (scripts Firebase)
scripts/node_modules/

# Build genérico na raiz
/build/
dist/

# Logs e temporários
*.log
*.tmp
.cache/

# Secrets locais (nunca commitar)
.env
.env.*
**/google-services.json
**/GoogleService-Info.plist
firebase-debug.log
firestore-debug.log
ui-debug.log
